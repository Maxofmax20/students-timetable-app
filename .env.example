# Students Timetable — environment template
# Copy to .env and fill with real secrets/URLs for your environment.

# Canonical production uses PostgreSQL.
DATABASE_URL="postgresql://students_timetable_app:change-me@127.0.0.1:5432/students_timetable"

# NextAuth / auth secrets
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://demostb.duckdns.org"
NEXT_PUBLIC_APP_URL="https://demostb.duckdns.org"

# SMTP / email / OTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="Students Timetable <noreply@example.com>"

# Optional OAuth providers (currently disabled in the live path)
AUTH_ENABLE_GOOGLE="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

AUTH_ENABLE_GITHUB="false"
GITHUB_ID=""
GITHUB_SECRET=""
